# Required — OpenAI API key for embeddings
OPENAI_API_KEY=sk-...

# Tool name prefix (optional) — tools become {prefix}_ask, {prefix}_memorize, etc.
# Example: MEMEX_PREFIX=reza → reza_ask, reza_memorize
# Leave empty for clean names: ask, memorize, forget, reflect
# (MCP already namespaces them as mcp__memex__ask)
MEMEX_PREFIX=

# Display name in tool descriptions
# Example: MEMEX_OWNER=Reza → "Search Reza's knowledge base..."
MEMEX_OWNER=the user

# Embedding model and dimensions
# IMPORTANT: text-embedding-3-large supports Matryoshka truncation.
# 1024 dims outperforms ada-002 at full 1536 for short personal entries.
# If you change MEMEX_EMBEDDING_DIMS after data has been stored, you MUST
# delete the LanceDB table directory and re-seed — mixing dims causes errors.
MEMEX_EMBEDDING_MODEL=text-embedding-3-large
MEMEX_EMBEDDING_DIMS=1024

# Data directory (default: ./data/kb)
# MEMEX_DATA_DIR=/path/to/your/data/kb

# Export path (default: ./data/backup.json)
# MEMEX_EXPORT_PATH=/path/to/backup.json

# Temporal decay scoring — Tiered Weibull model
# Replaces the old flat exponential with a three-tier Weibull decay.
#
# ALPHA: weight of semantic similarity vs. freshness (0-1). Default: 0.7
# HALF_LIFE: base freshness half-life in days. Default: 90
#
# Weibull tiers (β controls decay shape):
#   Core tier (personal/preference): β < 1 → fast initial drop then plateau
#   Working tier (decision/project/routing): β = 1 → standard exponential
#   Peripheral tier (reference/unknown): β > 1 → accelerating decay
#
# WEIBULL_MU: importance modulation strength. Higher = importance has bigger effect. Default: 1.5
# WEIBULL_BETA_CORE: shape parameter for core tier. Default: 0.8
# WEIBULL_BETA_WORKING: shape parameter for working tier. Default: 1.0
# WEIBULL_BETA_PERIPHERAL: shape parameter for peripheral tier. Default: 1.3
#
# Access reinforcement: retrieval extends half-life logarithmically, decaying over ACCESS_DECAY_DAYS.
# MAX_HALF_LIFE_MULTIPLIER: cap on how much access can extend half-life. Default: 3.0
#
# MEMEX_DECAY_ALPHA=0.7
# MEMEX_DECAY_HALF_LIFE=90
# MEMEX_WEIBULL_MU=1.5
# MEMEX_WEIBULL_BETA_CORE=0.8
# MEMEX_WEIBULL_BETA_WORKING=1.0
# MEMEX_WEIBULL_BETA_PERIPHERAL=1.3
# MEMEX_ACCESS_DECAY_DAYS=30
# MEMEX_MAX_HALF_LIFE_MULTIPLIER=3.0

# Relevance filtering (applies to ask, not reflect)
# MIN_SCORE: floor threshold — results below this cosine similarity are dropped. Default: 0.35
# GAP_RATIO: drop results more than (1 - ratio) below top score. Default: 0.75
#            Example: top=0.85, threshold=0.85*0.75=0.6375 — anything below is dropped.
# MAX_RESULTS: hard cap on returned results after all filtering. Default: 5
# MEMEX_MIN_SCORE=0.35
# MEMEX_GAP_RATIO=0.75
# MEMEX_MAX_RESULTS=5

# Insert-time deduplication (cosine similarity thresholds)
# DEDUP_EXACT: skip insert, return existing entry with duplicate:true. Default: 0.97
# DEDUP_NEAR:  insert but flag with near_duplicate:true, let caller decide. Default: 0.94
# MEMEX_DEDUP_EXACT=0.97
# MEMEX_DEDUP_NEAR=0.94

# Admission control — multi-factor gate before any entry is stored
# Scores each candidate on: type prior (50%), novelty (30%), content quality (20%)
#
# ADMISSION_ADMIT:  score at or above → store normally. Default: 0.55
# ADMISSION_REJECT: score below → reject with explanation. Default: 0.35
# Between the two → store but flag as low-confidence in the response.
#
# MEMEX_ADMISSION_ADMIT=0.55
# MEMEX_ADMISSION_REJECT=0.35

# Seed sources (for npm run seed)
# MEMEX_SEED_MD_DIR=/path/to/markdown/files
# MEMEX_SEED_BACKUP=/path/to/backup.json
# MEMEX_SEED_ROUTING_DB=/path/to/routing.db
